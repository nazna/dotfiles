[user]
  name = nazna
  email = 14846330+nazna@users.noreply.github.com
[init]
  defaultBranch = main
[core]
  editor = vim
  precomposeunicode = true
  ignorecase = false
  quotepath = false
  pager = LESSCHARSET=utf-8 less -FRX
[fetch]
  prune = true
  pruneTags = true
[pull]
  ff = only
[push]
  default = simple
  autoSetupRemote = true
[rebase]
  autoSquash = true
  autoStash = true
  updateRefs = true
[status]
  showUntrackedFiles = all
[branch]
  sort = -committerdate
[commit]
  verbose = true
[diff]
  algorithm = histogram
  colorMoved = plain
  mnemonicPrefix = true
  renames = true
  compactionHeuristic = true
[tag]
  sort = version:refname
[rerere]
  enabled = true
  autoupdate = true
[ghq]
  root = ~/work

[user]
  name = nazna
  email = 14846330+nazna@users.noreply.github.com
[init]
  defaultBranch = main
[core]
  editor = vim
  pager = LESSCHARSET=utf-8 less -FRX
  autocrlf = input
  quotepath = false
  ignorecase = false
[fetch]
  prune = true
  pruneTags = true
[pull]
  ff = only
[push]
  default = simple
  autoSetupRemote = true
[commit]
  verbose = true
[status]
  showUntrackedFiles = all
[branch]
  sort = -committerdate
[tag]
  sort = version:refname
[column]
  ui = auto
[color]
  ui = auto
  diff = always
  grep = always
  branch = always
  status = always
  interactive = always
[diff]
  algorithm = histogram
  mnemonicPrefix = true
  renames = true
  compactionHeuristic = true
[rerere]
  enabled = true
  autoupdate = true
[ghq]
  root = ~/work
